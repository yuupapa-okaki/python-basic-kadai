      "source": [
        "# 上辺・下辺・高さ\n",
        "upper_side = 10\n",
        "lower_side = 20\n",
        "height = 5\n",
        "\n",
        "# 台形の面積を計算\n",
        "area = (upper_side + lower_side) * height / 2\n",
        "\n",
        "# 結果を表示\n",
        "print(\"台形の面積は\", area, \"cm2です\")"
      ]
    }
  ]
