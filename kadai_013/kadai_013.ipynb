      "source": [
        "def calc_tax(price, tax_rate):\n",
        "    # 消費税を計算\n",
        "    tax = price * tax_rate / 100\n",
        "\n",
        "    # 税込み金額を計算して返す\n",
        "    return price + tax\n",
        "\n",
        "# 引数：商品金額110円、消費税10%\n",
        "result = calc_tax(110, 10)\n",
        "\n",
        "print(result)"
      ]
    }
  ]
